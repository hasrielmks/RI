      "id": "oQBTN5yonPLD"
    },
    {
      "cell_type": "code",
      "source": [
        "# Función para buscar los textos más similares a una imagen\n",
        "def image_to_text_search(image_url, text_embeddings, text_names, top_k=3):\n",
        "    \"\"\"\n",
        "    Encuentra los textos más similares a una imagen dada\n",
        "    \"\"\"\n",
        "    # Obtener embedding de la imagen consulta\n",
        "    query_embedding = get_image_embedding(image_url)\n",
        "    query_embedding = query_embedding.reshape(1, -1)\n",
        "\n",
        "    # Calcular similitud con todos los textos\n",
        "    similarities = cosine_similarity(query_embedding, text_embeddings)[0]\n",
        "\n",
        "    # Obtener top-k índices\n",
        "    top_indices = np.argsort(similarities)[::-1][:top_k]\n",
        "\n",
        "    # Mostrar resultados\n",
        "    print(f\"Búsqueda por imagen: {image_url[:50]}...\")\n",
        "    print(\"-\" * 50)\n",
        "    for idx in top_indices:\n",
        "        print(f\"  {text_names[idx]}: similitud = {similarities[idx]:.4f}\")\n",
        "\n",
        "    return top_indices, similarities[top_indices]\n",
        "\n",
        "# Ejemplos de búsqueda imagen → texto\n",
        "test_images = image_urls[:3]  # Usar las primeras 3 imágenes como ejemplo\n",
        "\n",
        "for img_url in test_images:\n",
        "    print()\n",
        "    image_to_text_search(img_url, text_embeddings, text_names)"
      ],
      "metadata": {
