    {
      "cell_type": "code",
      "source": [
        "# Obtener embeddings de imágenes\n",
        "print(\"Obteniendo embeddings de imágenes...\")\n",
        "image_embeddings = []\n",
        "for url in image_urls:\n",
        "    try:\n",
        "        emb = get_image_embedding(url)\n",
        "        image_embeddings.append(emb)\n",
        "        print(f\"✓ Imagen procesada: {url[:50]}...\")\n",
        "    except Exception as e:\n",
        "        print(f\"✗ Error con imagen {url}: {e}\")\n",
        "        # Usar embedding de ceros como fallback\n",
        "        image_embeddings.append(np.zeros(model.projection_dim))\n",
        "\n",
        "# Obtener embeddings de textos\n",
        "print(\"\\nObteniendo embeddings de textos...\")\n",
        "text_embeddings = []\n",
        "for text in texts:\n",
        "    try:\n",
        "        emb = get_text_embedding(text)\n",
        "        text_embeddings.append(emb)\n",
        "        print(f\"✓ Texto procesado: {text}\")\n",
        "    except Exception as e:\n",
        "        print(f\"✗ Error con texto {text}: {e}\")\n",
        "        text_embeddings.append(np.zeros(model.projection_dim))\n",
        "\n",
        "# Convertir a arrays numpy\n",
        "image_embeddings = np.array(image_embeddings)\n",
        "text_embeddings = np.array(text_embeddings)\n",
        "\n",
        "print(f\"\\nEmbeddings obtenidos:\")\n",
        "print(f\"  - Imágenes: {image_embeddings.shape}\")\n",
        "print(f\"  - Textos: {text_embeddings.shape}\")\n",
        "print(f\"  - Misma dimensión: {image_embeddings.shape[1] == text_embeddings.shape[1]}\")"
      ],
