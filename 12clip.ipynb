    {
      "cell_type": "markdown",
      "source": [
        "# **1.   Obtener embeddings de imágenes y textos con CLIP.**\n",
        "\n",
        "## **Función para obtener embeddings**"
      ],
      "metadata": {
        "id": "mxEdIPXfmDIJ"
      },
      "id": "mxEdIPXfmDIJ"
    },
    {
      "cell_type": "code",
      "source": [
        "def get_image_embedding(image_path_or_url):\n",
        "    \"\"\"\n",
        "    Obtiene el embedding de una imagen usando CLIP\n",
        "    \"\"\"\n",
        "    # Si es URL, descargar la imagen\n",
        "    if image_path_or_url.startswith('http'):\n",
        "        response = requests.get(image_path_or_url)\n",
        "        image = Image.open(BytesIO(response.content))\n",
        "    else:\n",
        "        image = Image.open(image_path_or_url)\n",
        "\n",
        "    # Procesar la imagen\n",
        "    inputs = processor(images=image, return_tensors=\"pt\").to(device)\n",
        "\n",
        "    # Obtener embedding\n",
        "    with torch.no_grad():\n",
        "        embedding = model.get_image_features(**inputs)\n",
        "        embedding = embedding / embedding.norm(dim=-1, keepdim=True)  # Normalizar\n",
        "\n",
        "    return embedding.cpu().numpy().flatten()\n",
        "\n",
        "def get_text_embedding(text):\n",
        "    \"\"\"\n",
        "    Obtiene el embedding de un texto usando CLIP\n",
        "    \"\"\"\n",
        "    # Procesar el texto\n",
        "    inputs = tokenizer(text, return_tensors=\"pt\", padding=True, truncation=True).to(device)\n",
        "\n",
        "    # Obtener embedding\n",
        "    with torch.no_grad():\n",
        "        embedding = model.get_text_features(**inputs)\n",
        "        embedding = embedding / embedding.norm(dim=-1, keepdim=True)  # Normalizar\n",
        "\n",
        "    return embedding.cpu().numpy().flatten()"
      ],
      "metadata": {
        "id": "Sc8Ckdg3g7rX"
      },
      "id": "Sc8Ckdg3g7rX",
      "execution_count": null,
      "outputs": []
