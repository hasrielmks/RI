        "    \"una playa paradisíaca con palmeras\",\n",
        "    \"un perro feliz jugando\"\n",
        "]\n",
        "\n",
        "# Nombres para identificar cada elemento\n",
        "image_names = [\"Comida\", \"Computadora\", \"Auto\", \"Playa\", \"Perro\"]\n",
        "text_names = [\"Texto Comida\", \"Texto Computadora\", \"Texto Auto\", \"Texto Playa\", \"Texto Perro\"]"
      ],
