    },
    {
      "cell_type": "code",
      "source": [
        "# Función para buscar las imágenes más similares a un texto\n",
        "def text_to_image_search(query_text, image_embeddings, image_names, top_k=3):\n",
        "    \"\"\"\n",
        "    Encuentra las imágenes más similares a un texto dado\n",
        "    \"\"\"\n",
        "    # Obtener embedding del texto consulta\n",
        "    query_embedding = get_text_embedding(query_text)\n",
        "    query_embedding = query_embedding.reshape(1, -1)\n",
        "\n",
        "    # Calcular similitud con todas las imágenes\n",
        "    similarities = cosine_similarity(query_embedding, image_embeddings)[0]\n",
        "\n",
        "    # Obtener top-k índices\n",
        "    top_indices = np.argsort(similarities)[::-1][:top_k]\n",
        "\n",
        "    # Mostrar resultados\n",
        "    print(f\"Búsqueda: '{query_text}'\")\n",
        "    print(\"-\" * 50)\n",
        "    for idx in top_indices:\n",
        "        print(f\"  {image_names[idx]}: similitud = {similarities[idx]:.4f}\")\n",
        "\n",
        "    return top_indices, similarities[top_indices]\n",
        "\n",
        "# Ejemplos de búsqueda texto → imagen\n",
        "test_queries = [\n",
        "    \"comida saludable\",\n",
        "    \"tecnología portátil\",\n",
        "    \"vehículo de lujo\",\n",
        "    \"vacaciones en la playa\",\n",
        "    \"mascota juguetona\"\n",
        "]\n",
        "\n",
        "for query in test_queries:\n",
        "    print()\n",
        "    text_to_image_search(query, image_embeddings, image_names)"
      ],
      "metadata": {
        "id": "-1lmdVGrj6do"
      },
      "id": "-1lmdVGrj6do",
      "execution_count": null,
      "outputs": []
