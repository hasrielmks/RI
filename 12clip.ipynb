        "    \"https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=400\",  # Playa\n",
        "    \"https://images.unsplash.com/photo-1517841905240-472988babdf9?w=400\"   # Perro\n",
        "]\n",
        "\n",
        "texts = [\n",
        "    \"una comida saludable con verduras\",\n",
        "    \"una computadora portátil moderna\",\n",
