        "\n",
        "# Calcular similitud de pares correctos e incorrectos\n",
        "print(\"\\nVerificando correspondencias:\")\n",
        "for i in range(len(image_names)):\n",
        "    cos_sim = cosine_similarity([image_embeddings[i]], [text_embeddings[i]])[0][0]\n",
        "    print(f\"  {image_names[i]} ↔ {text_names[i]}: {cos_sim:.4f}\")"
      ],
