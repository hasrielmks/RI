    {
      "cell_type": "code",
      "source": [
        "# Crear y visualizar la matriz de similitud completa\n",
        "similarity_matrix = cosine_similarity(image_embeddings, text_embeddings)\n",
        "\n",
        "plt.figure(figsize=(10, 8))\n",
        "plt.imshow(similarity_matrix, cmap='coolwarm', aspect='auto', vmin=0, vmax=1)\n",
        "plt.colorbar(label='Similitud coseno')\n",
        "plt.xticks(range(len(text_names)), text_names, rotation=45, ha='right')\n",
        "plt.yticks(range(len(image_names)), image_names)\n",
        "plt.title('Matriz de Similitud entre Imágenes y Textos')\n",
        "\n",
        "# Añadir valores en cada celda\n",
        "for i in range(len(image_names)):\n",
        "    for j in range(len(text_names)):\n",
        "        plt.text(j, i, f'{similarity_matrix[i, j]:.2f}',\n",
        "                ha='center', va='center', color='black' if similarity_matrix[i, j] < 0.5 else 'white')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Resaltar los pares correctos (diagonal)\n",
        "print(\"Similitudes de pares correctos (diagonal):\")\n",
        "for i in range(len(image_names)):\n",
        "    print(f\"  {image_names[i]} ↔ {text_names[i]}: {similarity_matrix[i, i]:.4f}\")"
      ],
